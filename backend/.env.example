APP_NAME=GanadoVision Backend
APP_ENV=local
APP_PORT=8000
DATABASE_URL=postgresql+asyncpg://ganado_user:ganado_pass@postgres:5432/ganado_db
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=INFO
TF_SERVING_WEIGHT_URL=http://tf-serving:8501/v1/models/weight:predict
AI_FAKE_MODE=true
AI_CACHE_TTL_SECONDS=3600
AI_MAX_IMAGE_SIZE_MB=5
